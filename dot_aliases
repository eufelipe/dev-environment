# ~/.aliases — gerenciado por chezmoi

# ---- Configs ----
alias zshconfig='cursor ~/.zshrc'
alias aliasconfig='cursor ~/.aliases'
alias exportsconfig='cursor ~/.exports'
alias functionsconfig='cursor ~/.functions'
alias gitconfig='cursor ~/.gitconfig'
alias sshconfig='cursor ~/.ssh/config'
alias reload='source ~/.zshrc'                 # recarrega o shell sem reabrir o terminal

# ---- Geral ----
alias c='clear'
alias l='eza -lah --git'
alias ll='eza -lah --git'
alias ls='eza'
alias cat='bat'
alias mkdir='mkdir -p'
alias grep='grep --color=auto'
alias please='sudo !!'                         # repete o ÚLTIMO comando com sudo

# ---- Apagar com segurança ----
alias del='trash'                              # vai pra Lixeira (reversível)

# ---- Navegação ----
alias ..='cd ..'
alias ...='cd ../..'
alias home='cd ~'
alias dev='cd ~/Projects'
alias downloads='cd ~/Downloads'
alias folder='open .'                          # abre a pasta atual no Finder

# Atalhos de projeto são por máquina — defina em ~/.zshrc.local (fora do git).

# ---- Finder: mostrar/esconder ocultos ----
alias show='defaults write com.apple.finder AppleShowAllFiles -bool true  && killall Finder'
alias hide='defaults write com.apple.finder AppleShowAllFiles -bool false && killall Finder'

# ---- Sistema / rede ----
alias localip='ipconfig getifaddr en0'         # IP local da Wi-Fi (interface en0)
alias ip="ifconfig | grep 'inet ' | grep -v 127.0.0.1 | awk '{print \$2}'"  # IP local (qualquer interface)
alias ports='lsof -i -P -n | grep LISTEN'      # quais processos estão escutando em portas
alias flushdns='sudo dscacheutil -flushcache && sudo killall -HUP mDNSResponder && echo flushed'  # limpa o cache de DNS
alias pingg='ping -c 5 google.com'             # testa a internet (5 pings no Google)
alias cpu='top -o cpu'                         # processos ordenados por uso de CPU
alias mem='top -o rsize'                       # processos ordenados por uso de RAM
alias update='brew update && brew upgrade'     # atualiza o Homebrew e os pacotes
alias cleanup='brew cleanup'                   # remove versões/caches antigos do brew

# ---- Git ----
alias gs='git status -sb'
alias lg='lazygit'                             # interface visual (TUI) pro git

# ---- Pacotes (pnpm preferido) ----
alias pn='pnpm'
alias pni='pnpm install'
alias pnd='pnpm dev'
alias pnt='pnpm test'
alias y='yarn'
alias ni='npm install'
alias nd='npm run dev'

# ---- React Native / mobile ----
alias metro='npx react-native start'
alias metro-reset='npx react-native start --reset-cache'   # inicia o Metro limpando o cache (resolve builds "fantasma")
alias rn='npx react-native'
alias rnios='npx react-native run-ios'
alias rnandroid='npx react-native run-android'
alias devices='adb devices'                    # lista dispositivos/emuladores Android
alias iosdevices='xcrun xctrace list devices'  # lista dispositivos/simuladores iOS
alias podreset='cd ios && pod_run deintegrate && pod_run install && cd ..'  # reinstala os Pods do zero (pod_run: bundler se houver Gemfile)
alias derived='trash ~/Library/Developer/Xcode/DerivedData/*'  # limpa caches de build do Xcode (libera GBs)

# ---- Docker ----
alias dps='docker ps'                          # containers rodando
alias dimg='docker images'                     # imagens locais
alias dcup='docker compose up -d'              # sobe os serviços do compose em background
alias dcdown='docker compose down'             # para e remove os serviços
alias dclogs='docker compose logs -f'          # acompanha os logs ao vivo
alias dbash='docker exec -it'                  # abre um shell dentro de um container (dbash <id> bash)

# ---- IA ----
# claude-safe: sandbox no host via agent-safehouse (instale: github.com/eugene1g/agent-safehouse)
command -v safehouse >/dev/null && alias claude-safe='safehouse claude'
command -v safehouse >/dev/null && alias claude-safe-skip='safehouse claude --dangerously-skip-permissions'

# ---- Útils ----
alias ytaudio='yt-dlp -x --audio-format mp3'   # baixa só o áudio (mp3) de um vídeo
alias weather='curl --silent http://wttr.in/Rio'  # previsão do tempo no terminal (Rio)
